---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Spiritual Intelligence — understanding why critical thinking matters in metaphysical and spiritual spaces.', ogImage = '/images/og/default.png' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, 'https://spiritualintelligence.cc').href;
const ogImageUrl = new URL(ogImage, 'https://spiritualintelligence.cc').href;
const fullTitle = `${title} | Spiritual Intelligence`;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SI Protocols',
  url: 'https://spiritualintelligence.cc',
  sameAs: ['https://spiritualintelligence.dev'],
  description: 'Understanding why critical thinking matters in metaphysical and spiritual spaces.',
};

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Spiritual Intelligence',
  url: 'https://spiritualintelligence.cc',
  description,
};
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Spiritual Intelligence" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{fullTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
