---
const links = [
  { href: '/', label: 'Home' },
  { href: '/why-spiritual-intelligence-matters/', label: 'Why It Matters' },
  { href: '/common-threats/', label: 'Common Threats' },
  { href: '/the-virtualisation-model/', label: 'The Model' },
  { href: 'https://spiritualintelligence.dev', label: 'For Developers', external: true },
];
const currentPath = Astro.url.pathname;
---

<header>
  <nav>
    <a href="/" class="logo glow">[SI]</a>
    <button class="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
    <ul>
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[{ active: currentPath.startsWith(link.href) && link.href !== '/' || currentPath === link.href && link.href === '/' }]}
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.label}{link.external ? ' \u2197' : ''}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const ul = toggle?.closest('nav')?.querySelector('ul');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    ul?.classList.toggle('open');
  });
</script>

<style>
  header {
    border-bottom: 1px solid var(--colour-border);
    background: var(--colour-surface);
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--colour-primary);
  }

  .logo:hover {
    color: var(--colour-primary);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--colour-text-muted);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .menu-toggle[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  ul {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    padding: 0;
    margin: 0;
  }

  li { margin: 0; }

  a {
    color: var(--colour-text-muted);
    font-size: 0.85rem;
  }

  a:hover,
  a.active {
    color: var(--colour-primary);
  }

  @media (max-width: 640px) {
    .menu-toggle {
      display: flex;
    }

    ul {
      display: none;
      flex-direction: column;
      width: 100%;
      gap: 0;
      padding-top: 0.75rem;
    }

    ul.open {
      display: flex;
    }

    li a {
      display: block;
      padding: 0.5rem 0;
    }
  }
</style>
